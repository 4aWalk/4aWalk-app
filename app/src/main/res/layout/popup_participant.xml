<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/popup_background">

    <!-- Header avec texte et bouton fermer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Participant 1"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/black"/>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Fermer"/>
    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginBottom="8dp"/>

    <!-- Champs sécurisés -->
    <EditText
        android:id="@+id/etAge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Âge"
        android:textColor="@android:color/black"
        android:textColorHint="@android:color/darker_gray"
        android:backgroundTint="@android:color/black"
        android:inputType="number"
        android:minHeight="48dp"/>

    <!-- Spinner pour Niveau -->
    <Spinner
        android:id="@+id/spinnerNiveau"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:entries="@array/niveaux"
        android:background="@drawable/spinner"/>

    <!-- Spinner pour Morphologie -->
    <Spinner
        android:id="@+id/spinnerMorphologie"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:entries="@array/morphologies"
        android:background="@drawable/spinner" />

    <EditText
        android:id="@+id/etBesoinKcal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Besoin kcal/jour"
        android:textColor="@android:color/black"
        android:textColorHint="@android:color/darker_gray"
        android:backgroundTint="@android:color/black"
        android:inputType="number"
        android:minHeight="48dp"/>

    <EditText
        android:id="@+id/etBesoinEau"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Besoin en eau (L)"
        android:textColor="@android:color/black"
        android:textColorHint="@android:color/darker_gray"
        android:backgroundTint="@android:color/black"
        android:inputType="numberDecimal"
        android:minHeight="48dp"/>

    <!-- Checkbox -->
    <CheckBox
        android:id="@+id/cbSacADos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Possède un sac à dos"
        android:textColor="@android:color/black"
        android:buttonTint="@android:color/black"
        android:layout_marginTop="8dp"
        android:padding="8dp"/>

    <EditText
        android:id="@+id/etCapacite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Capacité (kg) du sac"
        android:textColor="@android:color/black"
        android:textColorHint="@android:color/darker_gray"
        android:backgroundTint="@android:color/black"
        android:inputType="number"
        android:layout_marginTop="4dp"
        android:minHeight="48dp"/>

    <!-- Boutons -->
    <Button
        android:id="@+id/btnValider"
        android:text="Ajouter le participant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/lightvert"/>

    <Button
        android:id="@+id/btnVoirSac"
        android:text="Voir le sac à dos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/grey"/>
</LinearLayout>

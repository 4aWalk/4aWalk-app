<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/imgProfil"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_person"
            android:tint="@color/primary"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/txtNomComplet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:layout_marginEnd="6dp"
                android:textColor="@color/primary_dark" />

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_edit"
                android:tint="@color/primary_dark" />
        </LinearLayout>

        <!-- Section infos -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/adresse_personnelle"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:textColor="@color/primary_dark" />

        <TextView
            android:id="@+id/txtAdresse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="18 avenue durant de gros"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txtAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Age : 21 ans"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email : neo.become@edu-todaz.fr"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtNiveau"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Niveau : Entraîné"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtMorphologie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Morphologie : Moyen"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
